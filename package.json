{
  "name": "vue-shortcut-manager",
  "version": "1.0.6",
  "description": "Zero-config keyboard shortcut manager for Vue 3. No plugin, no main.ts setup.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "vue",
    "vue3",
    "shortcuts",
    "hotkeys",
    "keyboard",
    "keybindings",
    "composable"
  ],
  "author": "orazchollaev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/orazchollaev/vue-shortcut-manager"
  },
  "bugs": {
    "url": "https://github.com/orazchollaev/vue-shortcut-manager/issues"
  },
  "homepage": "https://github.com/orazchollaev/vue-shortcut-manager#readme",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  }
}
